# ==========================
# Application
# ==========================
APP_NAME=VoiceBridge AI
APP_VERSION=1.0.0
DEBUG=True

# ==========================
# Server
# ==========================
HOST=127.0.0.1
PORT=8000

# ==========================
# Database
# ==========================
DATABASE_URL=postgresql://postgres:password@localhost:5432/voicebridge

# ==========================
# JWT Authentication
# ==========================
JWT_SECRET_KEY=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================
# Deepgram
# ==========================
DEEPGRAM_API_KEY=

# ==========================
# IndicTrans2
# ==========================
INDICTRANS_MODEL=ai4bharat/indictrans2-en-indic

# ==========================
# ElevenLabs
# ==========================
ELEVENLABS_API_KEY=

# ==========================
# Smallest AI
# ==========================
SMALLEST_AI_API_KEY=

# ==========================
# OpenAI
# ==========================
OPENAI_API_KEY=

# ==========================
# Google Gemini
# ==========================
GEMINI_API_KEY=

# ==========================
# ChromaDB
# ==========================
CHROMA_DB_PATH=./chroma_db

# ==========================
# Uploads
# ==========================
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE=10485760

# ==========================
# Logging
# ==========================
LOG_LEVEL=INFO